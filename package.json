{
  "name": "nube-system",
  "version": "1.0.6",
  "description": "A modern utility-first CSS framework with semantic theme tokens",
  "main": "dist/index.js",
  "style": "styles/global-classes.css",
  "files": [
    "styles",
    "README.md",
    "scripts"
  ],
  "scripts": {
    "build": "npm run build:variables && npm run build:classes",
    "build:variables": "sass src/variables.scss styles/variables.css --style compressed",
    "build:classes": "sass src/main.scss styles/global-classes.css --style compressed",
    "prepare": "npm run build",
    "postinstall": "node scripts/setup-astro.js"
  },
  "keywords": [
    "css",
    "scss",
    "utility-first",
    "framework"
  ],
  "author": "Stefan Vaskovic",
  "license": "MIT",
  "devDependencies": {
    "sass": "^1.69.0"
  },
  "peerDependencies": {
    "sass": "^1.69.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StefanV22/nube-system-1.0.git"
  },
  "bugs": {
    "url": "https://github.com/StefanV22/nube-system-1.0/issues"
  }
}
