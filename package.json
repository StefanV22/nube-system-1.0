{
  "name": "nube-system",
  "version": "1.0.2",
  "description": "A modern, responsive SCSS utility framework with clamp-based responsive sizing",
  "main": "styles/global-classes.css",
  "style": "styles/global-classes.css",
  "files": [
    "styles",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:variables && npm run build:classes",
    "build:variables": "sass src/core/_variables.scss styles/variables.css --style compressed",
    "build:classes": "sass src/main.scss styles/global-classes.css --style compressed",
    "prepare": "npm run build"
  },
  "keywords": [
    "css",
    "scss",
    "utility",
    "framework",
    "responsive",
    "clamp",
    "css-variables",
    "utility-first"
  ],
  "author": "Don Vaskez",
  "license": "MIT",
  "devDependencies": {
    "sass": "^1.69.0"
  },
  "peerDependencies": {
    "sass": "^1.69.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StefanV22/nube-system-1.0.git"
  },
  "bugs": {
    "url": "https://github.com/StefanV22/nube-system-1.0/issues"
  }
}
